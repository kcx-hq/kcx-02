%% Use Case: Reset Password
%% Limitation: class diagrams do not expose password reset request/initiation; only token state methods are modeled.
sequenceDiagram
    actor ClientUser
    participant PasswordResetRequest

    ClientUser->>PasswordResetRequest: isExpired(now: DateTime): Boolean
    alt Token valid
        ClientUser->>PasswordResetRequest: markUsed(usedAt: DateTime)
        PasswordResetRequest-->>ClientUser: token consumed
    else Token expired
        PasswordResetRequest-->>ClientUser: token invalid/expired
    end