{
  "name": "backend",
  "version": "1.0.0",
  "description": "Minimal Express + Sequelize + PostgreSQL starter with migrations",
  "main": "dist/server.js",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true,maxRetries:10,retryDelay:200});\"",
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "ingest:aws:manual": "node dist/scripts/manual-aws-export-ingestion.js",
    "ingest:cloudtrail:files": "node dist/scripts/process-cloudtrail-files.js",
    "anomalies:run": "node dist/scripts/run-anomaly-detectors.js",
    "anomalies:test:backfill": "npm run build && node dist/scripts/test-billing-anomaly-detection-from-parquet.js",
    "backfill:anomalies": "npm run build && node dist/scripts/backfill-anomaly-detection.js",
    "backfill:cost-aggregations": "npm run build && node dist/scripts/backfill-cost-aggregations.js",
    "backfill:db-explorer": "npm run build && node dist/scripts/backfill-db-explorer.js",
    "backfill:ec2-cost-history": "npm run build && node dist/scripts/backfill-ec2-cost-history.js",
    "backfill:ec2-instance-cost-daily": "npm run build && node dist/scripts/backfill-ec2-instance-cost-daily.js",
    "backfill:ec2-instance-coverage-daily": "npm run build && node dist/scripts/backfill-ec2-instance-coverage-daily.js",
    "backfill:ec2-instance-daily": "npm run build && node dist/scripts/backfill-ec2-instance-daily.js",
    "demo:anomaly-data": "npm run build && node dist/scripts/generate-anomaly-demo-data.js",
    "recommendations:ec2:sync": "npm run build && node dist/scripts/generate-ec2-optimization-recommendations.js",
    "seed:cloud-connections:demo": "npm run build && node dist/scripts/seed-cloud-connections-demo.js",
    "seed:database-explorer:dev": "npm run build && node dist/scripts/seed/dev/seed-database-explorer-dev.js",
    "backfill:ebs-volume-utilization-hourly": "npm run build && node dist/scripts/backfill-ebs-volume-utilization-hourly.js",
    "backfill:ebs-volume-utilization-daily": "npm run build && node dist/scripts/backfill-ebs-volume-utilization-daily.js",
    "backfill:ebs-volume-daily": "npm run build && node dist/scripts/backfill-ebs-volume-daily.js",
    "recover:stale:ec2-inventory-job": "npm run build && node dist/scripts/recover-stale-ec2-inventory-job.js",
    "diagnose:billing:parquet": "node scripts/diagnose-billing-parquet.mjs",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:migrate": "npm run build && sequelize db:migrate --config dist/src/config/db.config.js --migrations-path dist/src/migrations",
    "db:migrate:undo": "npm run build && sequelize db:migrate:undo --config dist/src/config/db.config.js --migrations-path dist/src/migrations",
    "db:seed": "npm run build && sequelize db:seed:all --config dist/src/config/db.config.js --seeders-path dist/src/seeders",
    "db:migrate:single": "tsx scripts/run-single-migration.ts",
    "db:demo:reset": "tsx scripts/db-demo-reset.ts",
    "db:demo:seed": "tsx scripts/db-demo-seed.ts",
    "db:demo:rebuild": "tsx scripts/db-demo-rebuild.ts",
    "validate:ec2-demo": "tsx scripts/validate-ec2-demo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1027.0",
    "@aws-sdk/client-compute-optimizer": "^3.1026.0",
    "@aws-sdk/client-cost-explorer": "^3.1028.0",
    "@aws-sdk/client-ec2": "^3.1021.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1027.0",
    "@aws-sdk/client-s3": "^3.903.0",
    "@aws-sdk/client-sts": "^3.1020.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/multer": "2.0.0",
    "apache-arrow": "^16.1.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "parquet-wasm": "^0.6.1",
    "parquetjs-lite": "^0.8.7",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.7.1",
    "sequelize": "^6.37.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "sequelize-cli": "^6.6.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0"
  }
}
