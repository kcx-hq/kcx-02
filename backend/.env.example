DB_URL=postgres://username:password@host:5432/database_name?sslmode=require
PORT=5000
LOG_LEVEL=info

# Mailgun (required for outgoing emails)
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM="KCX <no-reply@yourdomain.com>"

# Frontend public URL used in backend-generated emails (password reset, invites)
# Local development: http://localhost:5173
# Production: https://app.yourdomain.com
FRONTEND_BASE_URL="http://localhost:5173"
# Optional CORS allow-list (comma-separated)
# Example: "http://localhost:5173,https://app.yourdomain.com"
CORS_ALLOWED_ORIGINS=""
# Optional: set this when Chromium is installed in a custom path
# PUPPETEER_EXECUTABLE_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
# Optional compatibility alias if your platform already provides CLIENT_URL
# CLIENT_URL="https://app.yourdomain.com"
RESET_TOKEN_TTL_MINUTES=60
SESSION_TTL_HOURS=1

# Admin panel (used by /admin/auth/login)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Cal.com (required API key, others optional with defaults)
CAL_API_KEY=""
CAL_API_BASE_URL="https://api.cal.com/v2"
CAL_EVENT_TYPE_ID=""
CAL_TIMEZONE="UTC"
CAL_RESERVATION_TTL_MINUTES=15

# AWS auto cloud connection callback
# Tip: for Cloudflared, use your tunnel URL + /api/aws/callback
AWS_CALLBACK_URL="https://yourdomain.com/api/aws/callback"
AWS_FILE_EVENT_CALLBACK_URL="https://yourdomain.com/api/aws/export-file-arrived"

# CloudFormation nested templates
AWS_PARENT_TEMPLATE_URL=""
AWS_BILLING_TEMPLATE_URL=""
AWS_CLOUDTRAIL_TEMPLATE_URL=""
AWS_ACTION_ROLE_TEMPLATE_URL=""
AWS_EC2_MODULE_TEMPLATE_URL=""
AWS_CLOUDWATCH_MODULE_TEMPLATE_URL=""

# AWS credentials used by backend services
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# AWS first parquet-file detection poller (milliseconds)
AWS_FIRST_FILE_POLLING_INTERVAL_MS=300000

# Billing ingestion tuning (optional)
# Rows processed per ETL chunk (default: 1000)
BILLING_INGESTION_BATCH_SIZE=5000
# Minimum milliseconds between ingestion status DB updates (default: 2000)
BILLING_INGESTION_STATUS_MIN_INTERVAL_MS=1000
# Temporary S3 upload session TTL in minutes (recommended range: 30-60)
BILLING_S3_UPLOAD_SESSION_TTL_MINUTES=45

# EC2 scheduled jobs poller (V1: DB polling, interval schedules)
EC2_SCHEDULED_JOBS_SCHEDULER_ENABLED=true
# Poll cadence in milliseconds (default: 60000)
EC2_SCHEDULED_JOBS_POLL_INTERVAL_MS=60000
# Consider a running job stale after this many milliseconds (default: 21600000 = 6h)
EC2_SCHEDULED_JOBS_RUNNING_STALE_AFTER_MS=21600000
# Rows claimed per poll batch (default: 10)
EC2_SCHEDULED_JOBS_BATCH_SIZE=10
# Max batches per poll tick (default: 5)
EC2_SCHEDULED_JOBS_MAX_BATCHES_PER_POLL=5

# S3 bucket config snapshot scheduler
# Runs S3 bucket-level configuration API scan and writes snapshots.
S3_BUCKET_CONFIG_SCHEDULER_ENABLED=true
# 24 hours
S3_BUCKET_CONFIG_SCHEDULER_INTERVAL_MS=86400000
# Initial delay after process start
S3_BUCKET_CONFIG_SCHEDULER_STARTUP_DELAY_MS=60000
