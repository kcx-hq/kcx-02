DB_URL=postgres://username:password@host:5432/database_name?sslmode=require
PORT=5000
LOG_LEVEL=info

# Mailgun (required for outgoing emails)
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM="KCX <no-reply@yourdomain.com>"

FRONTEND_BASE_URL="http://localhost:5173"
RESET_TOKEN_TTL_MINUTES=60
SESSION_TTL_HOURS=1


# Cal.com (required API key, others optional with defaults)
# Add your Cal.com API key from dashboard/settings
CAL_API_KEY=""
# Optional: override Cal.com base URL (default: https://api.cal.com/v2)
CAL_API_BASE_URL="https://api.cal.com/v2"
# Optional: event type id for filtering slots/booking against one event type
CAL_EVENT_TYPE_ID=""
# Optional: timezone sent to Cal.com requests (default: UTC)
CAL_TIMEZONE="UTC"
# Optional: fallback reservation expiry in minutes if API does not return it (default: 15)
CAL_RESERVATION_TTL_MINUTES=15


AWS_CALLBACK_URL="https://yourdomain.com/api/aws/callback"

AWS_ACCESS_KEY_ID=YOUR_KCX_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_KCX_SECRET_KEY
AWS_REGION=us-east-1
# Raw billing file storage (manual upload)
# Required: S3 bucket name where raw files are stored
RAW_BILLING_FILES_BUCKET=""
# Optional: AWS region (default: us-east-1)
AWS_REGION="us-east-1"
# Optional: explicit credentials (if not using instance/task role or default AWS chain)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional: session token for temporary credentials
AWS_SESSION_TOKEN=""
# Optional: custom S3-compatible endpoint (for MinIO/LocalStack/etc.)
AWS_S3_ENDPOINT=""
# Optional: use path-style addressing (default: false)
AWS_S3_FORCE_PATH_STYLE=false
